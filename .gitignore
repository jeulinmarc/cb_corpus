# Downloaded corpus (large, regenerable) — PDFs/reports/backups stay ignored,
# but the per-bank manifests (data/manifest/<bank>.jsonl) ARE committed so the
# corpus metadata is versioned and replayable.
data/*
!data/manifest/
data/manifest/*
!data/manifest/*.jsonl

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Docs — generated snapshots (regenerate via the scripts) + local working/analysis notes.
# Committed docs: README, INGESTION_RAG, BANKS, central_bank_corpus_inventory.
CORPUS.md
PRESENTATION.md
PRESENTATION_EN.md
*.pptx
ARCHITECTURE.md
DISCOVERY_AUDIT.md
COMPLETENESS.md
ECB_DOC_TYPES.md
